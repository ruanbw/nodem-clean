{
  "name": "nodem-clean",
  "version": "1.2.1",
  "description": "删除指定目录下的所有 node_modules 文件夹",
  "keywords": [
    "node_modules",
    "clean",
    "nodem-clean",
    "clear"
  ],
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "nodem-clean": "dist/bin/index.js"
  },
